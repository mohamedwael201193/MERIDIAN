{
  "name": "@meridian/x402-facilitator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MERIDIAN x402 facilitator + resource server (Casper testnet)",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:facilitator": "X402_MODE=facilitator node dist/index.js",
    "start:resource": "X402_MODE=resource node dist/index.js",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=verbose",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@casper-ecosystem/casper-eip-712": "=1.2.1",
    "@meridian/casper-sdk": "workspace:*",
    "@meridian/env": "workspace:*",
    "@upstash/redis": "=1.35.6",
    "casper-js-sdk": "=5.0.12",
    "express": "=5.0.1",
    "express-rate-limit": "=8.4.1",
    "pg": "=8.16.3",
    "prom-client": "=15.1.3",
    "zod": "=3.25.76"
  },
  "devDependencies": {
    "@types/express": "=5.0.0",
    "@types/pg": "=8.15.6",
    "vitest": "=3.2.4"
  }
}
