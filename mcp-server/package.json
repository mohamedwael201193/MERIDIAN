{
  "name": "@meridian/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MERIDIAN MCP server — 12 tools, stdio + HTTP",
  "bin": {
    "meridian-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:stdio": "MERIDIAN_MCP_TRANSPORT=stdio node dist/index.js",
    "start:http": "MERIDIAN_MCP_TRANSPORT=http node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:ci": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@casper-ecosystem/casper-eip-712": "1.2.1",
    "@meridian/casper-sdk": "workspace:*",
    "@meridian/env": "workspace:*",
    "@modelcontextprotocol/sdk": "=1.27.0",
    "casper-js-sdk": "=5.0.12",
    "express-rate-limit": "=8.4.1",
    "prom-client": "=15.1.3",
    "ws": "=8.18.0",
    "zod": "=3.25.76"
  },
  "devDependencies": {
    "@types/express": "=5.0.0",
    "@types/ws": "=8.5.13",
    "vitest": "=3.2.4"
  }
}
