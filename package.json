{
  "name": "meridian",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MERIDIAN — Casper RWA with native staking yield",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint && eslint .",
    "lint:fix": "pnpm -r run lint:fix && eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:ci": "pnpm -r run test:ci",
    "verify:env": "bash scripts/verify-env.sh",
    "verify:phase1": "node scripts/verify-phase1.mjs",
    "verify:all": "bash scripts/verify-all.sh",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "=9.39.1",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@types/node": "=22.19.1",
    "@types/pg": "=8.15.6",
    "@upstash/redis": "=1.35.6",
    "eslint": "=9.39.1",
    "globals": "=16.5.0",
    "lefthook": "=1.13.6",
    "pg": "=8.16.3",
    "prettier": "=3.6.2",
    "typescript": "=5.9.3",
    "typescript-eslint": "=8.48.0",
    "vitest": "^3.2.4"
  }
}
